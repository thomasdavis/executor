{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "CONVEX_URL",
        "DATABASE_URL",
        "VITE_CONVEX_URL",
        "WORKOS_API_KEY",
        "WORKOS_CLIENT_ID",
        "WORKOS_COOKIE_PASSWORD",
        "WORKOS_DEBUG_AUTH",
        "WORKOS_REDIRECT_URI"
      ]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    }
  }
}
